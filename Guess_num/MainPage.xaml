<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Guess_num.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            

            <Label
                Text="Welcome to Number Guessing game,      wish you well"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Lets start"
                Style="{StaticResource SubHeadline}"
                TextColor="Orange"
                SemanticProperties.HeadingLevel="Level2"/>

            <Label
                Text="Enter start range: "/>

            <Entry
                x:Name="start_range"
                Placeholder="Type here: "/>

            <Label
                Text="Enter range end point: "/>
            
            <Entry
                x:Name="end_range"
                Placeholder="Type here"/>

            <Label
                Text="Now enter your guesss-->"/>

            <Entry
                x:Name="user_input"
                Placeholder="enter guess here"/>




            <Button
                Text="lets guess"
                Clicked="OnCounterClicked"/>



          
            
            
            
            
            
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
